# Tawk.to live chat — required for the ChatWidget to open a real
# live chat panel. Without these the custom gold launcher still
# renders, but clicking it falls back to a "call us instead" prompt.
#
# How to get them:
#   1. Sign up free at https://www.tawk.to/
#   2. Create a property for Scott Electric Group
#   3. Admin → Channels → Chat Widget → copy the IDs from the embed
#      snippet. The URL looks like:
#      https://embed.tawk.to/<PROPERTY_ID>/<WIDGET_ID>
#
# Copy this file to .env.local and fill in the real values.
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=

# Microsoft 365 SMTP — required for the Partner & Support contact form
# (app/actions/contact.ts) to actually deliver submissions instead of
# failing silently. Sends through the existing discvault.app@discvault.site
# mailbox over SMTP — no third-party email service.
#
# How to get it:
#   1. SMTP_EMAIL is the mailbox address itself: discvault.app@discvault.site
#   2. SMTP_PASSWORD:
#      - If the mailbox has MFA enabled, you need an "app password"
#        (Microsoft 365 admin center → the user → Manage → Authentication
#        methods → App passwords), not the regular sign-in password.
#      - If the tenant has "Security Defaults" or a Conditional Access
#        policy blocking basic auth, SMTP AUTH must be enabled for this
#        specific mailbox first: admin.microsoft.com → Users → select the
#        mailbox → Mail → Manage email apps → enable "Authenticated SMTP".
SMTP_EMAIL=
SMTP_PASSWORD=


# Supabase public catalog — used by the read-only website catalog search.
# The anon key must only have access to public-safe catalog rows/views.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: defaults to "discs" when omitted. Point this at a public-safe
# table or view containing brand/mold/type/flight-number fields.
SUPABASE_CATALOG_TABLE=
